      const q = randInt(3, 7);
      const parts = p + q;

      const partValue = (mode === "hard") ? randInt(6, 18) : randInt(4, 15);
      const totalSum = parts * partValue;
      const shareA = p * partValue;

      const correct = `$${shareA}`;
      const wrongSeeds = uniqueStrings([
        `$${q * partValue}`, `$${(p + 1) * partValue}`, `$${Math.max(1, (p - 1)) * partValue}`,
        `$${totalSum}`, `$${partValue}`, `$${shareA + partValue}`, `$${Math.max(0, shareA - partValue)}`,
      ], correct).slice(0, 12);

      const built = make8OptionsFromCorrect(correct, wrongSeeds);
      return { q: `Ali and Ben share <b>$${totalSum}</b> in the ratio <b>${p}:${q}</b>. How much does Ali get?`, hint: `Total parts = ${p}+${q}. Find 1 part, then multiply.`, options: built.options, correctIndex: built.correctIndex };
    }

    function genDifferenceRatio(mode) {
      const a = randInt(2, 6);
      const b = randInt(4, 9);
      const c = randInt(6, 12);

      const diffParts = c - a;
      const partValue = (mode === "hard") ? randInt(8, 20) : randInt(5, 15);
      const diff = diffParts * partValue;
      const totalAmt = (a + b + c) * partValue;

      const correct = `$${totalAmt}`;
      const wrongSeeds = uniqueStrings([
        `$${diff}`, `$${(a + b + c) * (partValue + 1)}`, `$${(a + b + c) * Math.max(1, partValue - 1)}`,
        `$${totalAmt + partValue * 2}`, `$${Math.max(0, totalAmt - partValue * 2)}`,
      ], correct).slice(0, 12);

      const built = make8OptionsFromCorrect(correct, wrongSeeds);
      return { q: `A, B and C share some money in the ratio <b>${a}:${b}:${c}</b>.\nIf C has <b>$${diff}</b> more than A, find the total amount of money.`, hint: `Difference in parts = ${c}-${a}. Find 1 part, then total parts.`, options: built.options, correctIndex: built.correctIndex };
    }

    function genSpeedConvert(mode) {
      const kmh = (mode === "hard") ? [36, 54, 72, 90, 108][randInt(0, 4)] : [36, 54, 72, 90][randInt(0, 3)];
      const ms = (kmh * 5) / 18;
      const correct = `${ms} m/s`;

      const wrongSeeds = uniqueStrings([
        `${kmh} m/s`, `${(ms + 1)} m/s`, `${Math.max(0, ms - 1)} m/s`,
        `${(kmh / 18).toFixed(1)} m/s`, `${(kmh * 18 / 5).toFixed(0)} m/s`,
      ], correct).slice(0, 12);

      const built = make8OptionsFromCorrect(correct, wrongSeeds);
      return { q: `Convert <b>${kmh} km/h</b> into <b>m/s</b>.`, hint: `km/h → m/s: multiply by 5/18.`, options: built.options, correctIndex: built.correctIndex };
    }

    function genUnitRate(mode) {
      const cost = (mode === "hard") ? randInt(6, 18) : randInt(4, 14);
      const grams = (mode === "hard") ? [250, 300, 400, 500, 750][randInt(0, 4)] : [200, 250, 400, 500][randInt(0, 3)];
      const per100 = Math.round((cost / grams) * 100 * 100) / 100;

      const correct = `$${per100} per 100g`;
      const wrongSeeds = uniqueStrings([
        `$${(cost / grams).toFixed(2)} per 100g`,
        `$${(per100 + 0.5).toFixed(2)} per 100g`,
        `$${Math.max(0, per100 - 0.5).toFixed(2)} per 100g`,
        `$${(per100 * 10).toFixed(2)} per 100g`,
        `$${(per100 / 10).toFixed(2)} per 100g`,
      ], correct).slice(0, 12);

      const built = make8OptionsFromCorrect(correct, wrongSeeds);
      return { q: `A packet costs <b>$${cost}</b> for <b>${grams}g</b>. What is the cost <b>per 100g</b>?`, hint: `Unit rate = cost ÷ grams × 100.`, options: built.options, correctIndex: built.correctIndex };
    }

    function genAvgSpeed(mode) {
      const d1 = (mode === "hard") ? randInt(30, 70) : randInt(20, 60);
      const s1 = [36, 54, 72][randInt(0, 2)];
      const t1 = (d1 / s1) * 3600;

      const d2 = (mode === "hard") ? randInt(25, 60) : randInt(15, 50);
      const mins2 = (mode === "hard") ? randInt(25, 55) : randInt(20, 50);
      const secs2 = [0, 20, 40][randInt(0, 2)];
      const t2 = mins2 * 60 + secs2;

      const totalD = d1 + d2;
      const totalT = t1 + t2;
      const avg = totalD / (totalT / 3600);
      const ans = Number(avg.toPrecision(3));

      const correct = `${ans} km/h`;
      const wrongSeeds = uniqueStrings([
        `${Number((avg + 2).toPrecision(3))} km/h`,
        `${Number((Math.max(0, avg - 2)).toPrecision(3))} km/h`,
        `${Number((avg).toFixed(1))} km/h`,
        `${Number((avg).toFixed(0))} km/h`,
      ], correct).slice(0, 12);

      const built = make8OptionsFromCorrect(correct, wrongSeeds);
      return { q: `A lorry travels <b>${d1} km</b> at <b>${s1} km/h</b>, then travels <b>${d2} km</b> in <b>${mins2} min ${secs2} s</b>.\nFind the average speed (3 s.f.).`, hint: `Average speed = total distance ÷ total time.`, options: built.options, correctIndex: built.correctIndex };
    }

    function genBestExchange(mode) {
      const r = (randInt(540, 620) / 100).toFixed(3);
      const s = (randInt(160, 190) / 1000).toFixed(3);
      const amt = (mode === "hard") ? randInt(300, 700) : randInt(200, 600);

      const hkInSG = amt * Number(r);
      const hkInHK = amt / Number(s);

      const correct = (hkInSG >= hkInHK) ? "Change in Singapore" : "Change in Hong Kong";
      const wrongSeeds = uniqueStrings([
        correct === "Change in Singapore" ? "Change in Hong Kong" : "Change in Singapore",
        "Both are the same",
        "Cannot be determined",
        "Change half-half",
        "Change in Singapore (estimate)",
        "Change in Hong Kong (estimate)",
      ], correct);

      const built = make8OptionsFromCorrect(correct, wrongSeeds);
      return { q: `Exchange decision:\nIn Singapore: <b>1 SGD = ${r} HKD</b>\nIn Hong Kong: <b>1 HKD = ${s} SGD</b>\nMelisa has <b>SGD ${amt}</b>. Where should she change to get MORE HKD?`, hint: `Compute both: SGD×rate vs SGD÷rate.`, options: built.options, correctIndex: built.correctIndex };
    }

    function genLinkedRatio(mode) {
      const r = randInt(2, 5);
      const b1 = randInt(3, 7);
      const b2 = randInt(5, 9);
      const y = randInt(1, 4);

      const lcm = (x, z) => (x * z) / gcd(x, z);
      const commonB = lcm(b1, b2);
      const mult1 = commonB / b1;
      const mult2 = commonB / b2;

      const R = r * mult1;
      const B = commonB;
      const Y = y * mult2;

      const unit = (mode === "hard") ? randInt(2, 6) * 2 : randInt(2, 5) * 2;
      const redBalls = R * unit;
      const blueBalls = B * unit;
      const yellowBalls = Y * unit;

      const addBlue = unit * randInt(3, 10);
      const newBlue = blueBalls + addBlue;

      const g = gcd(redBalls, newBlue);
      const rr = redBalls / g;
      const bb = newBlue / g;

      const correct = `${yellowBalls}`;
      const wrongSeeds = uniqueStrings([
        `${Y * unit + unit}`, `${Math.max(0, Y * unit - unit)}`, `${blueBalls}`, `${redBalls}`, `${Y * unit * 2}`,
      ], correct).slice(0, 12);

      const built = make8OptionsFromCorrect(correct, wrongSeeds);
      return { q: `A box contains red, blue and yellow balls.\nThe ratio of red to blue is <b>${r}:${b1}</b> and the ratio of blue to yellow is <b>${b2}:${y}</b>.\nIf <b>${addBlue}</b> blue balls are added, the ratio of red to blue becomes <b>${rr}:${bb}</b>.\nFind the number of yellow balls.`, hint: `Link the ratios by making the “blue” the same, then convert using units.`, options: built.options, correctIndex: built.correctIndex };
    }

    /* =========================
       QUESTION GENERATORS (G1)
       - No speed / no average speed
       - Unit-conversion ratio questions
