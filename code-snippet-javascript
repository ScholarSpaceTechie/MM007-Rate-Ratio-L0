        `${Math.max(1, sa - 1)}:${sb}`, `${sa + 1}:${sb}`,
        `${sa}:${Math.max(1, sb - 1)}`, `${sa * 2}:${sb}`, `${sa}:${sb * 2}`,
      ], correct).slice(0, 12);

      const built = make8OptionsFromCorrect(correct, wrongSeeds);
      return { q: `Simplify the ratio <b>${a} : ${b}</b>.`, hint: `Divide both terms by the HCF.`, options: built.options, correctIndex: built.correctIndex };
    }

    function genShareRatio(mode) {
