    // ✅ G1 Unit-conversion ratio (renamed from genG1UnitConversion → genG1)
    function genG1(mode) {
      const types = ["length", "mass", "volume", "time"];
      const type = types[randInt(0, types.length - 1)];

      // base: cm, g, mL, s
      const toBase = {
        length: (v, u) => (u === "m" ? v * 100 : v),
        mass: (v, u) => (u === "kg" ? v * 1000 : v),
        volume: (v, u) => (u === "L" ? v * 1000 : v),
        time: (v, u) => (u === "min" ? v * 60 : (u === "h" ? v * 3600 : v)),
      };

      function build(leftVal, leftUnit, rightVal, rightUnit, convFn) {
        const L = convFn(leftVal, leftUnit);
        const R = convFn(rightVal, rightUnit);

        // force integers (handle any decimals just in case)
        const scale = (x) => {
          const s = String(x);
          if (!s.includes(".")) return { n: Math.round(x), m: 1 };
          const dp = s.split(".")[1].length;
          const m = Math.pow(10, dp);
          return { n: Math.round(Number(x) * m), m };
        };
        const a = scale(L);
        const b = scale(R);
        const lInt = a.n * b.m;
        const rInt = b.n * a.m;

        const [sa, sb] = simplifyRatio(lInt, rInt);
        const correct = `${sa}:${sb}`;

        const wrongSeeds = uniqueStrings([
          `${sb}:${sa}`,
          `${lInt}:${rInt}`,           // not simplified
          `${sa}:${sb + 1}`,
          `${Math.max(1, sa - 1)}:${sb}`,
          `${sa + 1}:${sb}`,
          `${sa}:${Math.max(1, sb - 1)}`,
          `${sa * 2}:${sb}`,
          `${sa}:${sb * 2}`,
        ], correct).slice(0, 12);

        const built = make8OptionsFromCorrect(correct, wrongSeeds);
        return {
          q: `What is the ratio of <b>${leftVal}${leftUnit}</b> : <b>${rightVal}${rightUnit}</b> in simplest form?`,
          hint: `Convert both to the same unit first, then simplify.`,
          options: built.options,
          correctIndex: built.correctIndex,
        };
      }

      if (type === "volume") {
        const leftIsmL = randInt(0, 1) === 0;
        const leftVal = leftIsmL ? randInt(150, 950) : randInt(1, (mode === "hard") ? 25 : 15);
        const leftUnit = leftIsmL ? "mL" : "L";

        const rightUnit = leftIsmL ? "L" : "mL";
        const rightVal = (rightUnit === "L") ? randInt(2, (mode === "hard") ? 30 : 20) : randInt(200, 9000);

        return build(leftVal, leftUnit, rightVal, rightUnit, (v, u) => toBase.volume(v, u));
      }

      if (type === "length") {
        const leftIscm = randInt(0, 1) === 0;
        const leftVal = leftIscm ? randInt(15, 480) : randInt(1, (mode === "hard") ? 45 : 30);
        const leftUnit = leftIscm ? "cm" : "m";

        const rightUnit = leftIscm ? "m" : "cm";
        const rightVal = (rightUnit === "m") ? randInt(2, (mode === "hard") ? 60 : 40) : randInt(40, 9800);

        return build(leftVal, leftUnit, rightVal, rightUnit, (v, u) => toBase.length(v, u));
      }

      if (type === "mass") {
        const leftIsg = randInt(0, 1) === 0;
        const leftVal = leftIsg ? randInt(50, 950) : randInt(1, (mode === "hard") ? 35 : 20);
        const leftUnit = leftIsg ? "g" : "kg";

        const rightUnit = leftIsg ? "kg" : "g";
        const rightVal = (rightUnit === "kg") ? randInt(2, (mode === "hard") ? 45 : 30) : randInt(200, 20000);

        return build(leftVal, leftUnit, rightVal, rightUnit, (v, u) => toBase.mass(v, u));
      }

      // time
      const hard = mode === "hard";
      const units = hard ? ["s", "min", "h"] : ["s", "min"];
      const leftUnit = units[randInt(0, units.length - 1)];
      const rightUnit = units[randInt(0, units.length - 1)];

      const leftVal =
        leftUnit === "s" ? randInt(30, 420) :
        leftUnit === "min" ? randInt(2, 90) :
        randInt(1, 8);

      const rightVal =
        rightUnit === "s" ? randInt(60, 900) :
        rightUnit === "min" ? randInt(3, 120) :
        randInt(1, 10);

      return build(leftVal, leftUnit, rightVal, rightUnit, (v, u) => toBase.time(v, u));
    }

    // ✅ NEW: G1 mixed numbers / fractions / decimals ratio (no unit conversion)
    function genG1MixedFracRatio(mode) {
      const itemsA = ["onion", "carrot", "rice", "flour", "sugar", "oil", "potato"];
      const itemsB = ["potato", "tomato", "water", "milk", "butter", "salt", "beans"];
      const aName = itemsA[randInt(0, itemsA.length - 1)];
      const bName = itemsB[randInt(0, itemsB.length - 1)];

      // Build A and B as rationals
      // A: fraction OR mixed number
      const aType = randInt(0, 1); // 0 fraction, 1 mixed
      let A, Astr;

      if (aType === 0) {
        const n = randInt(1, 3);
        const d = randInt(n + 1, 8);
        A = ratFromFrac(n, d);
        Astr = `${n}/${d}`;
      } else {
        const w = randInt(1, (mode === "hard") ? 4 : 3);
        const n = randInt(1, 3);
        const d = randInt(n + 1, 8);
        A = ratFromMixed(w, n, d);
        Astr = `${w} ${n}/${d}`;
      }

      // B: decimal OR mixed number OR fraction
      const bType = randInt(0, 2); // 0 decimal, 1 mixed, 2 fraction
      let B, Bstr;

      if (bType === 0) {
        const base = (mode === "hard") ? [0.5, 1.5, 2.5, 3.5, 4.5] : [0.5, 1.5, 2.5, 3.5];
        const dec = base[randInt(0, base.length - 1)];
        B = ratFromDecimal(dec);
        Bstr = `${dec}`;
      } else if (bType === 1) {
        const w = randInt(1, (mode === "hard") ? 5 : 4);
        const n = randInt(1, 3);
        const d = randInt(n + 1, 8);
        B = ratFromMixed(w, n, d);
        Bstr = `${w} ${n}/${d}`;
      } else {
        const n = randInt(1, 5);
        const d = randInt(n + 1, 10);
        B = ratFromFrac(n, d);
        Bstr = `${n}/${d}`;
      }

      // Ratio A:B -> (A.n/A.d):(B.n/B.d) => A.n*B.d : B.n*A.d
      const left = A.n * B.d;
      const right = B.n * A.d;
      const [sa, sb] = simplifyRatio(left, right);
      const correct = `${sa}:${sb}`;

      const wrongSeeds = uniqueStrings([
        `${sb}:${sa}`,
        `${left}:${right}`,                // not simplified
        `${sa}:${sb + 1}`,
        `${Math.max(1, sa - 1)}:${sb}`,
        `${sa + 1}:${sb}`,
        `${sa}:${Math.max(1, sb - 1)}`,
        `${sa * 2}:${sb}`,
        `${sa}:${sb * 2}`,
      ], correct).slice(0, 12);

      const built = make8OptionsFromCorrect(correct, wrongSeeds);
      return {
        q: `A recipe uses <b>${Astr}</b> ${aName} for every <b>${Bstr}</b> ${bName}.\nWhat is the ratio <b>${aName} : ${bName}</b> in simplest form?`,
        hint: `Turn each number into a fraction, then clear denominators to get integers.`,
        options: built.options,
        correctIndex: built.correctIndex,
      };
    }

    function genG1FractionRatio(mode) {
      const p = randInt(1, 5);
      const q = randInt(2, 7);
      const n = p;
      const d = p + q;
      const correct = `${n}/${d}`;

      const wrongSeeds = uniqueStrings([
        `${q}/${d}`, `${n}/${q}`, `${n}/${d + 1}`,
        `${Math.max(1, n - 1)}/${d}`, `${n + 1}/${d}`, `${d}/${n}`,
      ], correct).slice(0, 12);

      const built = make8OptionsFromCorrect(correct, wrongSeeds);
      return {
        q: `The ratio of A to B is <b>${p}:${q}</b>. What fraction of the total is <b>A</b>?`,
        hint: `A fraction = A parts ÷ total parts.`,
        options: built.options,
        correctIndex: built.correctIndex,
      };
    }

    function genG1FractionOfQuantityInRatio(mode) {
      const p = randInt(2, 6);
      const q = randInt(3, 8);
      const parts = p + q;

      const unit = (mode === "hard") ? randInt(4, 20) : randInt(3, 15);
      const totalVal = parts * unit;
      const aAmt = p * unit;

      const correct = `${aAmt}`;
      const wrongSeeds = uniqueStrings([
        `${q * unit}`, `${totalVal}`, `${unit}`, `${aAmt + unit}`, `${Math.max(0, aAmt - unit)}`,
      ], correct).slice(0, 12);

      const built = make8OptionsFromCorrect(correct, wrongSeeds);
      return {
        q: `A and B share <b>${totalVal}</b> items in the ratio <b>${p}:${q}</b>.\nHow many items does <b>A</b> get?`,
        hint: `Find 1 part = total ÷ (${p}+${q}).`,
        options: built.options,
        correctIndex: built.correctIndex,
      };
    }

    function genG1UnitRateWithConversion(mode) {
      const type = randInt(0, 1) === 0 ? "mass" : "volume";
      let q = "", correct = "", wrongSeeds = [];

      if (type === "mass") {
        const cost = (mode === "hard") ? randInt(8, 28) : randInt(5, 18);
