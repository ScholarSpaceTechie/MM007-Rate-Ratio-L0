(function () {
  function initRatioRateGame() {
    const container = document.getElementById("ratio-rate-game-container");
    if (!container) return;

    // ----------------------------
    // Config
    // ----------------------------
    const GAME_ID = "rr"; // prefix for element IDs
    const TOTAL_QUESTIONS_PER_SESSION = 10;

    // Timer (seconds) by mode
    const MODE_CONFIG = {
      easy: { label: "Easy", timeLimit: 35 },
      normal: { label: "Normal", timeLimit: 45 },
      hard: { label: "Hard", timeLimit: 60 },
    };

    // ----------------------------
    // HTML (Percentage-style: title row + scoreboard + mode buttons)
    // ----------------------------
    container.innerHTML = `
      <div class="rr-game">
        <div class="rr-title-row">
          <h2 class="rr-title"><span>⚖️</span> <span style="color:#ffffff">Ratio & Rate Rush</span></h2>

          <div class="rr-scoreboard">
