    // ---------- FRACTION / RATIONAL HELPERS (for G1 mixed numbers, fractions, decimals) ----------
    // Rational stored as {n, d} with d>0, simplified
    function simpRat(n, d) {
      if (d === 0) return { n: 0, d: 1 };
      if (d < 0) { n = -n; d = -d; }
      const g = gcd(Math.abs(n), Math.abs(d));
      return { n: n / g, d: d / g };
    }

    function ratMul(a, b) { return simpRat(a.n * b.n, a.d * b.d); }
    function ratDiv(a, b) { return simpRat(a.n * b.d, a.d * b.n); }

    function ratFromFrac(n, d) { return simpRat(n, d); }

    // Decimal like 1.5 -> 3/2 (limited dp)
    function ratFromDecimal(x) {
      const s = String(x);
      if (!s.includes(".")) return simpRat(Number(x), 1);
      const dp = s.split(".")[1].length;
      const m = Math.pow(10, dp);
      return simpRat(Math.round(Number(x) * m), m);
    }

    // Mixed number: w a/b
    function ratFromMixed(w, a, b) {
      return simpRat(w * b + a, b);
    }

    function ratToNiceString(r) {
      // show as simplified fraction if not integer
      if (r.d === 1) return `${r.n}`;
      return `${r.n}/${r.d}`;
