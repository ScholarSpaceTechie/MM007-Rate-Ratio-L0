      const built = make8OptionsFromCorrect(correct, uniqueStrings(wrongSeeds, correct).slice(0, 12));
      return { q, hint: `Convert to the target unit first, then scale the cost.`, options: built.options, correctIndex: built.correctIndex };
    }

    function genG1RatioWithFractionGiven(mode) {
      const bn = randInt(1, 4);
      const bd = randInt(bn + 1, 7);
      const [sa, sb] = simplifyRatio(bn, bd);
      const correct = `${sa}:${sb}`;

      const wrongSeeds = uniqueStrings([
        `${sb}:${sa}`, `${bn}:${bd}`, `${sa}:${sb + 1}`,
        `${Math.max(1, sa - 1)}:${sb}`, `${sa + 1}:${sb}`,
        `${sa}:${Math.max(1, sb - 1)}`,
      ], correct).slice(0, 12);

      const built = make8OptionsFromCorrect(correct, wrongSeeds);
      return { q: `A is <b>${bn}/${bd}</b> of B. Find the ratio <b>A : B</b> in simplest form.`, hint: `Turn “A is a fraction of B” into a ratio, then simplify.`, options: built.options, correctIndex: built.correctIndex };
    }

